{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/gateway-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Gateway.Yarp"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "YourSuperSecretKeyThatShouldBeAtLeast32Characters!",
    "Issuer": "ECommerce.Identity",
    "Audience": "ECommerce.Client"
  },
  "ServiceUrls": {
    "Catalog": "http://localhost:6060",
    "Basket": "http://localhost:6061",
    "Order": "http://localhost:6062",
    "Identity": "http://localhost:6063",
    "Payment": "http://localhost:6065",
    "Notification": "http://localhost:6066"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "coupons-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/coupons/{**catch-all}"
        }
      },
      "wishlist-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/wishlist/{**catch-all}"
        }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/basket/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/payment/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6060"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6061"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6062"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6063"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6065"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:6066"
          }
        }
      }
    }
  }
}
